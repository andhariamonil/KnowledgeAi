# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Environment
.env
frontend/.env
backend/.env

# Build output
frontend/dist/
frontend/.vite/

# Uploads (user files — don't commit)
backend/uploads/*
!backend/uploads/.gitkeep

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Root Artifacts & Scripts (Ignore everything in root except specific files)
/*
!/backend/
!/frontend/
!/README.md
!/package.json
!/package-lock.json
!/.gitignore

# Ignore any binary or script files in root
/*.docx
/*.pptx
/*.pdf
/*.png
/*.jpg
/*.js